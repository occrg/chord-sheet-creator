{
  "name": "chord_sheet_creator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "reinstall-packages": "rm -rf node_modules && rm package-lock.json && npm i",
    "type-check": "vue-tsc --build",
    "build-only": "vite build",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-from-scratch": "npm run reinstall-packages && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "pinia": "^3.0.3",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.6",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.9.0",
    "vite": "^7.1.7",
    "vite-plugin-vue-devtools": "^8.0.2",
    "vue-tsc": "^3.1.0"
  }
}
